rules_version = '2';
// Reglas de Firestore para La Buena Familia.
// Modelo: datos COMPARTIDOS por todo el grupo, pero SOLO entre miembros autorizados.
//
// Control de acceso por ALLOWLIST de emails:
//   - Un usuario logueado solo cuenta como "miembro" si su email está en la
//     colección `allowed/{email}` (un documento vacío por cada email permitido).
//   - Aunque un extraño se registre, si su email no está en `allowed`, no puede
//     leer ni escribir ningún dato del grupo.
//   - La colección `allowed` NO se puede modificar desde el cliente: solo se
//     administra a mano desde la consola de Firebase (Firestore → allowed).
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'nimoirano@gmail.com';
    }

    function isMember() {
      return request.auth != null
        && request.auth.token.email != null
        && (isAdmin()
            || exists(/databases/$(database)/documents/allowed/$(request.auth.token.email)));
    }

    // Allowlist: el dueño lee su propio registro; el admin lee/escribe todo (aprueba accesos).
    match /allowed/{email} {
      allow read:  if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // Solicitudes de acceso: un logueado crea/lee SOLO la suya; el admin las ve y resuelve.
    match /accessRequests/{uid} {
      allow read:   if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    match /players/{id} {
      allow read: if isMember();
      allow create: if isMember();
      allow update: if isMember();
      allow delete: if isMember();
    }

    match /bans/{id} {
      allow read: if isMember();
      allow create: if isMember() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isMember();
      // borra el autor o cualquier miembro (grupo de amigos)
      allow delete: if isMember();
    }

    match /screenshots/{id} {
      allow read: if isMember();
      allow create: if isMember() && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if isMember() && resource.data.uploadedBy == request.auth.uid;
    }

    match /comments/{id} {
      allow read: if isMember();
      allow create: if isMember() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isMember() && resource.data.authorId == request.auth.uid;
    }
  }
}
